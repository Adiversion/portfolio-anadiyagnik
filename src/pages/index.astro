---
const projects = [
  {
    id: "tds",
    num: "01",
    title: "Direct-from-Tally TDS Compliance Engine",
    imageCount: 7,
    imagePrefix: "/images/tds/tds-",
    desc: `Built a full-cycle TDS management system connecting Excel directly to Tally Prime
via ODBC — eliminating all manual ledger exports. Auto-calculates interest, late fees,
and flags "No PAN" entries for higher deduction under Section 206AA. Integrated with
TRACES portal for bulk PAN verification, instantly identifying inoperative PANs.`,
    impact: `Reduced 3–4 day manual TDS cycle to <strong>~1 working day</strong> across 8 entities.
PAN verification for 50+ records: ~4 hours → <strong>15 minutes</strong>.`,
    tech: ["Tally ODBC","Advanced Excel","TRACES Portal","Section 206AA","VBA"],
    reverse: false,
  },
  {
    id: "loan",
    num: "02",
    title: "LoanGuard Pro — Automated Loan Tracking",
    imageCount: 5,
    imagePrefix: "/images/loan/loan-",
    desc: `Robust Excel-based corporate loan management tool powered by Power Query M scripts
and VBA macros. Automatically generates EMI schedules, tracks real-time outstanding
balances, and sends reminders. Handles multi-crore amortisation across 1–8 year tenures.`,
    impact: `Achieved <strong>&gt;95% tracking accuracy</strong> over full loan lifecycles.
Eliminated missed payments and gave management real-time visibility.`,
    tech: ["Power Query / M","VBA Macros","EMI Scheduling","Cash Flow"],
    reverse: true,
  },
  {
    id: "pan",
    num: "03",
    title: "Bulk TRACES PAN Verification Tool",
    imageCount: 1,
    imagePrefix: "/images/pan/pan-",
    desc: `Excel-based tool integrating with the TRACES portal for bulk PAN validation at scale.
Instantly flags "Inoperative" PANs where Aadhaar linking is pending — ensuring correct
deduction rates per CBDT circular and eliminating the manual one-by-one bottleneck.`,
    impact: `Verification for <strong>50+ PAN records</strong> cut from ~4 hours to
<strong>15 minutes</strong> during Q1–Q2 2025.`,
    tech: ["TRACES Portal","Excel Automation","CBDT Compliance","PAN Validation"],
    reverse: false,
  },
];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <meta name="description" content="Senior Accountant & Finance Automation Lead. GST/TDS compliance automated with Excel, VBA, Power Query and Tally ODBC."/>
  <title>Anadi Shankar Yagnik — Finance Automation Specialist</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@300;400;500&family=Instrument+Sans:wght@400;500;600&display=swap" rel="stylesheet"/>
  <style>
    :root{
      --navy:#0b0f1a;--navy2:#111827;--navy3:#1a2235;--navy4:#243049;
      --gold:#c9a84c;--goldlt:#e3c97a;--golddim:#7a5f28;
      --slate:#8a97b0;--slatelt:#bec8d9;--white:#f0f4ff;--green:#3ecf8e;
      --border:rgba(201,168,76,.18);--borders:rgba(201,168,76,.35);
      --serif:'DM Serif Display',serif;--mono:'DM Mono',monospace;--sans:'Instrument Sans',sans-serif;
    }
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{background:var(--navy);color:var(--slatelt);font-family:var(--sans);font-size:16px;line-height:1.7;overflow-x:hidden}
    a{color:var(--gold);text-decoration:none}
    a:hover{color:var(--goldlt)}
    ::-webkit-scrollbar{width:6px}
    ::-webkit-scrollbar-track{background:var(--navy)}
    ::-webkit-scrollbar-thumb{background:var(--golddim);border-radius:3px}
    @keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
    @keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(.8)}}

    /* NAV */
    nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:1.25rem 4rem;background:rgba(11,15,26,.9);backdrop-filter:blur(16px);border-bottom:1px solid var(--border)}
    .nlogo{font-family:var(--serif);font-size:1.15rem;color:var(--gold)}
    .nlinks{display:flex;gap:2.5rem}
    .nlinks a{font-family:var(--mono);font-size:.78rem;letter-spacing:.1em;text-transform:uppercase;color:var(--slate);transition:color .2s}
    .nlinks a:hover{color:var(--goldlt)}
    .burger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:4px}
    .burger span{display:block;width:22px;height:2px;background:var(--slatelt);border-radius:2px}

    /* SHARED */
    section{padding:7rem 4rem}
    .sl{font-family:var(--mono);font-size:.72rem;letter-spacing:.2em;text-transform:uppercase;color:var(--gold);margin-bottom:1rem;display:flex;align-items:center;gap:.8rem}
    .sl::after{content:'';flex:1;max-width:60px;height:1px;background:var(--golddim)}
    h2{font-family:var(--serif);font-size:clamp(2rem,4vw,3rem);color:var(--white);line-height:1.15;margin-bottom:1rem}
    h2 em{font-style:italic;color:var(--gold)}
    .si{font-size:1.05rem;color:var(--slate);max-width:580px;line-height:1.8;margin-bottom:4rem}
    .divider{height:1px;background:linear-gradient(90deg,transparent,var(--borders),transparent);margin:0 4rem}
    .tag{font-family:var(--mono);font-size:.68rem;letter-spacing:.08em;background:var(--navy4);color:var(--slate);padding:.3rem .7rem;border-radius:2px;border:1px solid var(--border)}
    .btnp{display:inline-flex;align-items:center;gap:.5rem;background:var(--gold);color:var(--navy);padding:.8rem 2rem;font-family:var(--mono);font-size:.82rem;font-weight:500;letter-spacing:.1em;text-transform:uppercase;border-radius:2px;transition:all .2s}
    .btnp:hover{background:var(--goldlt);color:var(--navy);transform:translateY(-2px)}
    .btng{display:inline-flex;align-items:center;gap:.5rem;border:1px solid var(--borders);color:var(--slatelt);padding:.8rem 2rem;font-family:var(--mono);font-size:.82rem;letter-spacing:.1em;text-transform:uppercase;border-radius:2px;transition:all .2s}
    .btng:hover{border-color:var(--gold);color:var(--gold);transform:translateY(-2px)}

    /* HERO */
    .hero{min-height:100vh;display:flex;align-items:center;padding:8rem 4rem 6rem;position:relative;overflow:hidden}
    .hgrid{position:absolute;inset:0;background-image:linear-gradient(rgba(201,168,76,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(201,168,76,.04) 1px,transparent 1px);background-size:60px 60px}
    .hglow{position:absolute;top:-200px;right:-200px;width:700px;height:700px;background:radial-gradient(circle,rgba(201,168,76,.08) 0%,transparent 70%);pointer-events:none}
    .hglow2{position:absolute;bottom:-300px;left:-100px;width:600px;height:600px;background:radial-gradient(circle,rgba(62,207,142,.05) 0%,transparent 70%);pointer-events:none}
    .hcontent{position:relative;max-width:900px}
    .hbadge{display:inline-flex;align-items:center;gap:.5rem;font-family:var(--mono);font-size:.75rem;letter-spacing:.15em;text-transform:uppercase;color:var(--green);border:1px solid rgba(62,207,142,.3);padding:.35rem .9rem;border-radius:2px;margin-bottom:2rem;animation:fadeUp .6s ease both}
    .hbadge::before{content:'';width:6px;height:6px;background:var(--green);border-radius:50%;animation:pulse 2s infinite}
    .hero h1{font-family:var(--serif);font-size:clamp(3rem,7vw,5.5rem);line-height:1.08;color:var(--white);margin-bottom:.5rem;animation:fadeUp .6s .1s ease both}
    .hero h1 em{font-style:italic;color:var(--gold)}
    .hsub{font-family:var(--mono);font-size:.95rem;color:var(--slate);letter-spacing:.05em;margin-bottom:2rem;animation:fadeUp .6s .2s ease both}
    .hdesc{font-size:1.1rem;color:var(--slatelt);max-width:640px;line-height:1.8;margin-bottom:3rem;animation:fadeUp .6s .3s ease both}
    .hdesc strong{color:var(--goldlt);font-weight:600}
    .hcta{display:flex;gap:1.2rem;flex-wrap:wrap;animation:fadeUp .6s .4s ease both}
    .hstats{display:flex;gap:3rem;margin-top:4rem;animation:fadeUp .6s .5s ease both}
    .snum{font-family:var(--serif);font-size:2.8rem;color:var(--gold);line-height:1}
    .slbl{font-family:var(--mono);font-size:.7rem;letter-spacing:.1em;text-transform:uppercase;color:var(--slate);margin-top:.25rem}

    /* ABOUT — with profile photo */
    .about{background:var(--navy2)}
    .agrid{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:start}
    .atext p{margin-bottom:1.2rem;font-size:1.05rem;color:var(--slatelt);line-height:1.9}
    .atext strong{color:var(--goldlt)}

    /* Profile photo */
    .profile-wrap{display:flex;align-items:flex-start;gap:2rem;margin-bottom:2rem}
    .profile-photo{width:120px;height:120px;border-radius:50%;border:3px solid var(--gold);object-fit:cover;flex-shrink:0;box-shadow:0 0 0 6px rgba(201,168,76,.12),0 8px 32px rgba(0,0,0,.4)}
    .profile-intro{flex:1}
    .profile-intro h2{margin-bottom:.5rem}

    .acards{display:flex;flex-direction:column;gap:1rem}
    .icard{border:1px solid var(--border);background:var(--navy3);padding:1.25rem 1.75rem;border-radius:4px;position:relative;overflow:hidden}
    .icard::before{content:'';position:absolute;top:0;left:0;width:3px;height:100%;background:var(--gold)}
    .iclbl{font-family:var(--mono);font-size:.68rem;letter-spacing:.15em;text-transform:uppercase;color:var(--gold);margin-bottom:.4rem}
    .icval{font-size:.95rem;color:var(--white);font-weight:500;line-height:1.5}

    /* SKILLS */
    .skills{background:var(--navy)}
    .sgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem}
    .scard{border:1px solid var(--border);background:var(--navy3);padding:2rem;border-radius:4px;transition:border-color .3s,transform .3s;position:relative;overflow:hidden}
    .scard::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--gold),transparent);transform:scaleX(0);transform-origin:left;transition:transform .4s}
    .scard:hover{border-color:var(--borders);transform:translateY(-4px)}
    .scard:hover::after{transform:scaleX(1)}
    .sico{font-size:1.5rem;margin-bottom:1rem}
    .stitle{font-family:var(--serif);font-size:1.15rem;color:var(--white);margin-bottom:1rem}
    .stags{display:flex;flex-wrap:wrap;gap:.5rem}

    /* PROJECTS — balanced layout */
    .projects{background:var(--navy2)}
    .plist{display:flex;flex-direction:column;gap:3rem}
    .pcard{display:grid;grid-template-columns:1.2fr 1fr;align-items:center;border:1px solid var(--border);background:var(--navy3);border-radius:6px;overflow:hidden;transition:border-color .3s}
    .pcard:hover{border-color:var(--borders)}
    .pcard.rev{direction:rtl}
    .pcard.rev>*{direction:ltr}

    /* CAROUSEL — landscape */
    .carousel{position:relative;aspect-ratio:16/9;background:var(--navy);overflow:hidden;border-right:1px solid var(--border);user-select:none}
    .pcard.rev .carousel{border-right:none;border-left:1px solid var(--border)}

    .carousel-progress{position:absolute;top:0;left:0;height:3px;background:var(--gold);width:0%;z-index:10;transition:width linear}

    .carousel-track{display:flex;height:100%;will-change:transform}
    .carousel-track.animating{transition:transform .5s cubic-bezier(.4,0,.2,1)}
    .carousel-slide{min-width:100%;height:100%;position:relative;flex-shrink:0}
    .carousel-slide img{position:absolute;inset:0;width:100%;height:100%;object-fit:contain;background:var(--navy);display:block}

    .carousel-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(11,15,26,.7) 0%,transparent 40%);pointer-events:none;z-index:2}

    .carousel-bar{position:absolute;bottom:0;left:0;right:0;display:flex;align-items:center;gap:.75rem;padding:.75rem 1rem;z-index:3}
    .cbtn{background:rgba(11,15,26,.6);border:1px solid rgba(201,168,76,.35);color:var(--gold);width:34px;height:34px;border-radius:3px;cursor:pointer;font-size:1.2rem;display:flex;align-items:center;justify-content:center;transition:all .2s;flex-shrink:0;line-height:1}
    .cbtn:hover{background:rgba(201,168,76,.25);border-color:var(--gold)}
    .cbtn:disabled{opacity:.2;cursor:not-allowed}
    .cdots{display:flex;gap:.45rem;align-items:center;flex:1;justify-content:center}
    .cdot{width:7px;height:7px;border-radius:50%;background:rgba(255,255,255,.3);border:none;cursor:pointer;padding:0;transition:all .25s;flex-shrink:0}
    .cdot.on{background:var(--gold);transform:scale(1.35)}
    .ccounter{font-family:var(--mono);font-size:.7rem;letter-spacing:.08em;color:rgba(255,255,255,.7);flex-shrink:0}

    .cpause{background:rgba(11,15,26,.6);border:1px solid rgba(201,168,76,.2);color:rgba(255,255,255,.5);width:28px;height:28px;border-radius:50%;cursor:pointer;font-size:.65rem;display:flex;align-items:center;justify-content:center;transition:all .2s;flex-shrink:0;padding:0}
    .cpause:hover{border-color:var(--gold);color:var(--gold)}

    .pbody{padding:2.5rem}
    .pnum{font-family:var(--mono);font-size:.7rem;letter-spacing:.2em;color:var(--gold);margin-bottom:.75rem}
    .ptitle{font-family:var(--serif);font-size:1.5rem;color:var(--white);margin-bottom:1rem;line-height:1.2}
    .pdesc{font-size:.92rem;color:var(--slatelt);line-height:1.85;margin-bottom:1.25rem}
    .pimp{background:var(--navy4);border-left:3px solid var(--green);padding:.9rem 1.15rem;border-radius:0 4px 4px 0;margin-bottom:1.25rem}
    .pilbl{font-family:var(--mono);font-size:.65rem;letter-spacing:.15em;text-transform:uppercase;color:var(--green);margin-bottom:.35rem}
    .pitxt{font-size:.88rem;color:var(--slatelt)}
    .pitxt strong{color:var(--green)}
    .ptech{display:flex;flex-wrap:wrap;gap:.5rem}

    /* EXPERIENCE */
    .experience{background:var(--navy)}
    .etl{position:relative;padding-left:2rem;max-width:860px}
    .etl::before{content:'';position:absolute;top:0;bottom:0;left:0;width:1px;background:linear-gradient(to bottom,var(--gold),var(--golddim),transparent)}
    .eitem{position:relative;margin-bottom:3.5rem;padding-left:2.5rem}
    .eitem::before{content:'';position:absolute;left:-2.35rem;top:.35rem;width:10px;height:10px;background:var(--gold);border-radius:50%;border:2px solid var(--navy);box-shadow:0 0 0 4px rgba(201,168,76,.15)}
    .edate{font-family:var(--mono);font-size:.72rem;letter-spacing:.1em;color:var(--gold);margin-bottom:.4rem}
    .etitle{font-family:var(--serif);font-size:1.35rem;color:var(--white);margin-bottom:.2rem}
    .eco{font-family:var(--mono);font-size:.82rem;color:var(--slate);letter-spacing:.04em;margin-bottom:1rem}
    .eco span{color:var(--slatelt)}
    .eul{list-style:none}
    .eul li{position:relative;padding-left:1.2rem;margin-bottom:.6rem;font-size:.95rem;color:var(--slatelt);line-height:1.7}
    .eul li::before{content:'›';position:absolute;left:0;color:var(--gold);font-size:1.1rem;line-height:1.5}

    /* EDUCATION */
    .education{background:var(--navy2)}
    .edugrid{display:grid;grid-template-columns:repeat(2,1fr);gap:1.5rem}
    .educard{border:1px solid var(--border);background:var(--navy3);padding:2.5rem;border-radius:4px;transition:border-color .3s;position:relative;overflow:hidden}
    .educard::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--gold),transparent)}
    .educard:hover{border-color:var(--borders)}
    .educard.hl{border-color:rgba(62,207,142,.3)}
    .educard.hl::before{background:linear-gradient(90deg,var(--green),transparent)}
    .educard.hl .eduyear{color:var(--green)}
    .eduyear{font-family:var(--mono);font-size:.7rem;letter-spacing:.15em;text-transform:uppercase;color:var(--gold);margin-bottom:.75rem}
    .edudeg{font-family:var(--serif);font-size:1.25rem;color:var(--white);margin-bottom:.4rem;line-height:1.3}
    .edusch{font-size:.88rem;color:var(--slate);line-height:1.5}
    .edusta{display:inline-flex;align-items:center;gap:.4rem;font-family:var(--mono);font-size:.65rem;color:var(--green);letter-spacing:.1em;text-transform:uppercase;margin-top:.85rem;background:rgba(62,207,142,.1);padding:.25rem .6rem;border-radius:2px;border:1px solid rgba(62,207,142,.2)}
    .edusta::before{content:'';width:5px;height:5px;background:var(--green);border-radius:50%;animation:pulse 2s infinite}

    /* CONTACT */
    .contact{background:var(--navy)}
    .cgrid{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:start}
    .cnote{font-size:1rem;color:var(--slate);line-height:1.9;margin-bottom:2rem}
    .cnote strong{color:var(--goldlt)}
    .avail{display:inline-flex;align-items:center;gap:.6rem;font-family:var(--mono);font-size:.75rem;letter-spacing:.1em;text-transform:uppercase;color:var(--green);border:1px solid rgba(62,207,142,.25);padding:.6rem 1.2rem;border-radius:2px;background:rgba(62,207,142,.07)}
    .avail::before{content:'';width:7px;height:7px;background:var(--green);border-radius:50%;animation:pulse 2s infinite}
    .clinks{display:flex;flex-direction:column;gap:1rem;margin-top:1rem}
    .clink{display:flex;align-items:center;gap:1.25rem;border:1px solid var(--border);background:var(--navy3);padding:1.25rem 1.75rem;border-radius:4px;color:var(--slatelt);transition:border-color .3s,transform .3s}
    .clink:hover{border-color:var(--gold);color:var(--goldlt);transform:translateX(6px)}
    .clico{font-size:1.2rem}
    .clinfo{flex:1;display:flex;flex-direction:column}
    .cllbl{font-family:var(--mono);font-size:.65rem;letter-spacing:.15em;text-transform:uppercase;color:var(--slate);margin-bottom:.2rem}
    .clval{font-size:.95rem;color:inherit}

    /* FOOTER */
    footer{padding:2rem 4rem;border-top:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.75rem;background:var(--navy2)}
    .fname{font-family:var(--serif);font-size:1rem;color:var(--gold)}
    .fnote{font-family:var(--mono);font-size:.68rem;letter-spacing:.08em;color:var(--slate)}

    /* RESPONSIVE */
    @media(max-width:900px){
      nav{padding:1rem 1.5rem}
      .nlinks{display:none}
      .nlinks.open{display:flex;flex-direction:column;position:fixed;top:57px;left:0;right:0;background:rgba(17,24,39,.97);backdrop-filter:blur(16px);padding:2rem;gap:1.5rem;border-bottom:1px solid var(--border);z-index:99}
      .burger{display:flex}
      section{padding:5rem 2rem}
      .divider{margin:0 2rem}
      .hero{padding:7rem 2rem 4rem}
      .hstats{gap:2rem;flex-wrap:wrap}
      .agrid,.cgrid{grid-template-columns:1fr;gap:3rem}
      .sgrid{grid-template-columns:1fr 1fr}
      .pcard,.pcard.rev{grid-template-columns:1fr;direction:ltr}
      .carousel{aspect-ratio:16/9;border:none!important}
      .carousel-slide{min-height:unset}
      .edugrid{grid-template-columns:1fr}
      .profile-wrap{flex-direction:column;align-items:center;text-align:center}
      .profile-photo{width:100px;height:100px}
      footer{padding:1.5rem;justify-content:center;text-align:center}
    }
    @media(max-width:600px){.sgrid{grid-template-columns:1fr}.pbody{padding:1.75rem}}
    /* LIGHTBOX */
    .carousel-slide img{cursor:zoom-in}
    #lightbox{position:fixed;inset:0;z-index:9999;display:flex;align-items:center;justify-content:center;background:rgba(5,8,15,.96);backdrop-filter:blur(14px);opacity:0;pointer-events:none;transition:opacity .3s ease}
    #lightbox.open{opacity:1;pointer-events:all}
    #lightbox img{max-width:92vw;max-height:88vh;object-fit:contain;border-radius:4px;box-shadow:0 0 100px rgba(0,0,0,.9);display:block;transition:opacity .2s ease;user-select:none;-webkit-user-drag:none}
    #lightbox img.fading{opacity:0}
    .lb-close{position:fixed;top:1rem;right:1.25rem;background:rgba(201,168,76,.15);border:1px solid rgba(201,168,76,.45);color:var(--gold);width:46px;height:46px;border-radius:50%;cursor:pointer;font-size:1.5rem;display:flex;align-items:center;justify-content:center;transition:all .25s;z-index:10000;line-height:1}
    .lb-close:hover{background:rgba(201,168,76,.3);transform:rotate(90deg) scale(1.1)}
    .lb-prev,.lb-next{position:fixed;top:50%;transform:translateY(-50%);background:rgba(11,15,26,.75);border:1px solid rgba(201,168,76,.35);color:var(--gold);width:52px;height:52px;border-radius:4px;cursor:pointer;font-size:2rem;display:flex;align-items:center;justify-content:center;transition:all .2s;z-index:10000;line-height:1}
    .lb-prev{left:.75rem}.lb-next{right:.75rem}
    .lb-prev:hover,.lb-next:hover{background:rgba(201,168,76,.25);border-color:var(--gold)}
    .lb-prev:disabled,.lb-next:disabled{opacity:.15;cursor:not-allowed}
    .lb-info{position:fixed;bottom:1.25rem;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:.6rem;z-index:10000}
    .lb-counter{font-family:var(--mono);font-size:.78rem;letter-spacing:.12em;color:rgba(255,255,255,.55)}
    .lb-dots{display:flex;gap:.5rem}
    .lb-dot{width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,.25);border:none;cursor:pointer;padding:0;transition:all .25s}
    .lb-dot.on{background:var(--gold);transform:scale(1.35)}
    @media(max-width:600px){.lb-prev{left:.25rem}.lb-next{right:.25rem}.lb-prev,.lb-next{width:42px;height:42px;font-size:1.6rem}}
  </style>
</head>
<body>

<!-- NAV -->
