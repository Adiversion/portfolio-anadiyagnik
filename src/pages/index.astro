<script>
  /* ═══════════════════════════════════════════════
     MOBILE NAV
     ═══════════════════════════════════════════════ */
  const burger = document.getElementById('burger');
  const nl     = document.getElementById('nl');

  function closeNav() {
    nl?.classList.remove('open');
    burger?.setAttribute('aria-expanded', 'false');
  }

  burger?.addEventListener('click', () => {
    const isOpen = nl?.classList.toggle('open');
    burger.setAttribute('aria-expanded', String(!!isOpen));
  });

  document.querySelectorAll('#nl a').forEach(a =>
    a.addEventListener('click', closeNav)
  );

  document.addEventListener('click', (e) => {
    if (nl?.classList.contains('open') &&
        !nl.contains(e.target as Node) &&
        e.target !== burger &&
        !burger?.contains(e.target as Node)) {
      closeNav();
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && nl?.classList.contains('open')) closeNav();
  });


  /* ═══════════════════════════════════════════════
     NAV SCROLL + BACK-TO-TOP + ACTIVE LINK
     ═══════════════════════════════════════════════ */
  const navEl    = document.querySelector('nav');
  const btt      = document.getElementById('btt');
  const navLinks = document.querySelectorAll<HTMLAnchorElement>('.nlinks a:not(.nav-resume)');

  function onScroll() {
    navEl?.classList.toggle('scrolled', window.scrollY > 80);
    btt?.classList.toggle('show', window.scrollY > 600);
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
  btt?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

  const navObs = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        navLinks.forEach(link => {
          link.classList.toggle('active', link.getAttribute('href') === `#${entry.target.id}`);
        });
      }
    });
  }, { rootMargin: '-40% 0px -55% 0px' });

  Array.from(navLinks).forEach(a => {
    const id = a.getAttribute('href')?.replace('#', '');
    if (id) { const el = document.getElementById(id); if (el) navObs.observe(el); }
  });


  /* ═══════════════════════════════════════════════
     CAROUSELS
     ═══════════════════════════════════════════════ */
  const INTERVAL       = 5000;
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  document.querySelectorAll<HTMLElement>('.carousel').forEach(el => {
    const count = parseInt(el.dataset.count || '1');

    if (count <= 1) {
      el.dataset.current = '0';
      return;
    }

    const track    = el.querySelector<HTMLElement>('.carousel-track');
    const progress = el.querySelector<HTMLElement>('.carousel-progress');
    const counter  = el.querySelector<HTMLElement>('.ccounter');
    const prevBtn  = el.querySelector<HTMLButtonElement>('.cbtn.prev');
    const nextBtn  = el.querySelector<HTMLButtonElement>('.cbtn.next');
    const pauseBtn = el.querySelector<HTMLButtonElement>('.cpause');
    if (!track || !counter || !prevBtn || !nextBtn || !pauseBtn) return;
    const dots = el.querySelectorAll<HTMLButtonElement>('.cdot');

    let current = 0;
    let paused  = prefersReduced;
    let timer: ReturnType<typeof setTimeout>;

    function goTo(idx: number, animate = true) {
      current = ((idx % count) + count) % count;
      el.dataset.current = String(current);
      if (animate) {
        track!.classList.add('animating');
        track!.addEventListener('transitionend', () => track!.classList.remove('animating'), { once: true });
      }
      track!.style.transform = `translateX(-${current * 100}%)`;
      counter!.textContent   = `${current + 1} / ${count}`;
      dots.forEach((d, i) => d.classList.toggle('on', i === current));
    }

    function startProgress() {
      if (!progress) return;
      progress.style.transition = 'none';
      progress.style.width      = '0%';
      progress.getBoundingClientRect();
      progress.style.transition = `width ${INTERVAL}ms linear`;
      progress.style.width      = '100%';
    }

    function clearProgress() {
      if (!progress) return;
      progress.style.transition = 'none';
      progress.style.width      = '0%';
    }

    function scheduleNext() {
      clearTimeout(timer);
      if (!paused && count > 1) {
        startProgress();
        timer = setTimeout(() => { goTo(current + 1); scheduleNext(); }, INTERVAL);
      } else {
        clearProgress();
      }
    }

    function resetTimer() { clearTimeout(timer); scheduleNext(); }

    prevBtn.addEventListener('click', () => { goTo(current - 1); resetTimer(); });
    nextBtn.addEventListener('click', () => { goTo(current + 1); resetTimer(); });
    dots.forEach((d, i) => d.addEventListener('click', () => { goTo(i); resetTimer(); }));

    if (prefersReduced) {
      pauseBtn.textContent = '▶';
      pauseBtn.title = 'Resume autoplay';
    }

    pauseBtn.addEventListener('click', () => {
      paused = !paused;
      pauseBtn.textContent = paused ? '▶' : '⏸';
      pauseBtn.title       = paused ? 'Resume autoplay' : 'Pause autoplay';
      if (paused) { clearTimeout(timer); clearProgress(); }
      else scheduleNext();
    });

    el.addEventListener('mouseenter', () => { clearTimeout(timer); clearProgress(); });
    el.addEventListener('mouseleave', () => { if (!paused) scheduleNext(); });
    el.addEventListener('focusin',  () => { clearTimeout(timer); clearProgress(); });
    el.addEventListener('focusout', (e: FocusEvent) => {
      if (!el.contains(e.relatedTarget as Node) && !paused) scheduleNext();
    });

    let tx = 0;
    el.addEventListener('touchstart', (e: TouchEvent) => { tx = e.touches[0].clientX; }, { passive: true });
    el.addEventListener('touchend',   (e: TouchEvent) => {
      const diff = tx - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 45) { goTo(diff > 0 ? current + 1 : current - 1); resetTimer(); }
    }, { passive: true });

    el.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'ArrowRight') { goTo(current + 1); resetTimer(); }
      if (e.key === 'ArrowLeft')  { goTo(current - 1); resetTimer(); }
    });

    goTo(0, false);
    scheduleNext();
  });


  /* ═══════════════════════════════════════════════
     LIGHTBOX
     ═══════════════════════════════════════════════ */
  (function initLightbox() {
    const lb          = document.getElementById('lightbox');
    const mainContent = document.getElementById('main-content');
    if (!lb) return;

    const lbImg     = lb.querySelector<HTMLImageElement>('img')!;
    const lbClose   = lb.querySelector<HTMLButtonElement>('.lb-close')!;
    const lbPrev    = lb.querySelector<HTMLButtonElement>('.lb-prev')!;
    const lbNext    = lb.querySelector<HTMLButtonElement>('.lb-next')!;
    const lbCounter = lb.querySelector<HTMLElement>('.lb-counter')!;
    const lbDots    = lb.querySelector<HTMLElement>('.lb-dots')!;
    if (!lbImg || !lbClose || !lbPrev || !lbNext || !lbCounter || !lbDots) return;

    let images: string[] = [];
    let projectTitle     = '';
    let current          = 0;
    let isOpen           = false;

    /* ── OPEN ── */
    function openLightbox(carousel: HTMLElement, startIdx: number) {
      if (isOpen) return;
      const prefix = carousel.dataset.prefix || '';
      const count  = parseInt(carousel.dataset.count || '1');
      projectTitle = carousel.dataset.title || 'Project';
      images       = Array.from({ length: count }, (_, i) => `${prefix}${i + 1}.png`);
      current      = Math.min(startIdx, images.length - 1);

      renderDots();
      showSlide(current, false);

      lb.classList.add('open');
      lb.removeAttribute('inert');
      mainContent?.setAttribute('inert', '');
      document.body.style.overflow = 'hidden';
      isOpen = true;

      requestAnimationFrame(() => lbClose.focus());
    }

    /* ── CLOSE ── */
    function closeLightbox() {
      if (!isOpen) return;
      lb.classList.remove('open');
      lb.setAttribute('inert', '');
      mainContent?.removeAttribute('inert');
      document.body.style.overflow = '';
      isOpen = false;
    }

    /* ── DOTS ── */
    function renderDots() {
      lbDots.innerHTML = '';
      if (images.length <= 1) return;
      images.forEach((_, i) => {
        const d = document.createElement('button');
        d.className = 'lb-dot' + (i === current ? ' on' : '');
        d.setAttribute('aria-label', `View image ${i + 1}`);
        d.addEventListener('click', () => showSlide(i));
        lbDots.appendChild(d);
      });
    }

    /* ── SHOW SLIDE ── */
    function showSlide(idx: number, animate = true) {
      current = ((idx % images.length) + images.length) % images.length;
      const altText = `${projectTitle} — screenshot ${current + 1} of ${images.length}`;

      if (animate && !prefersReduced) {
        lbImg.classList.add('fading');
        setTimeout(() => {
          lbImg.src = images[current];
          lbImg.alt = altText;
          lbImg.onload = () => lbImg.classList.remove('fading');
        }, 200);
      } else {
        lbImg.src = images[current];
        lbImg.alt = altText;
        lbImg.classList.remove('fading');
      }

      lbCounter.textContent = `${current + 1} / ${images.length}`;
      lbDots.querySelectorAll('.lb-dot').forEach((d, i) =>
        d.classList.toggle('on', i === current)
      );
      lbPrev.disabled = images.length <= 1;
      lbNext.disabled = images.length <= 1;
    }

    /* ── BIND ALL CAROUSEL IMAGES ── */
    document.querySelectorAll<HTMLElement>('.carousel').forEach(carousel => {
      const slides = carousel.querySelectorAll<HTMLImageElement>('.carousel-slide img');

      /* Desktop: click on image opens lightbox */
      slides.forEach((img, idx) => {
        img.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          openLightbox(carousel, idx);
        });
      });

      /* Mobile: tap on image area opens lightbox (avoids swipe conflict) */
      let touchStartX = 0;
      let touchStartY = 0;
      let touchTime   = 0;

      carousel.addEventListener('touchstart', (e: TouchEvent) => {
        touchStartX = e.touches[0].clientX;
        touchStartY = e.touches[0].clientY;
        touchTime   = Date.now();
      }, { passive: true });

      carousel.addEventListener('touchend', (e: TouchEvent) => {
        const dx       = Math.abs(e.changedTouches[0].clientX - touchStartX);
        const dy       = Math.abs(e.changedTouches[0].clientY - touchStartY);
        const duration = Date.now() - touchTime;

        /* Quick tap only (not swipe): small movement + short duration */
        if (dx < 12 && dy < 12 && duration < 300) {
          const target = e.target as HTMLElement;
          if (target.closest('.carousel-bar')) return;
          const currentIdx = parseInt(carousel.dataset.current || '0');
          openLightbox(carousel, currentIdx);
        }
      }, { passive: true });

      /* Keyboard: Enter opens lightbox */
      carousel.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Enter') {
          e.preventDefault();
          const currentIdx = parseInt(carousel.dataset.current || '0');
          openLightbox(carousel, currentIdx);
        }
      });
    });

    /* ── LIGHTBOX CONTROLS ── */
    lbClose.addEventListener('click', (e) => { e.stopPropagation(); closeLightbox(); });
    lbPrev.addEventListener('click',  (e) => { e.stopPropagation(); showSlide(current - 1); });
    lbNext.addEventListener('click',  (e) => { e.stopPropagation(); showSlide(current + 1); });

    /* Click backdrop to close */
    lb.addEventListener('click', (e) => {
      if (e.target === lb) closeLightbox();
    });

    /* Keyboard nav inside lightbox */
    document.addEventListener('keydown', (e) => {
      if (!isOpen) return;
      if (e.key === 'Escape')     { e.preventDefault(); closeLightbox(); }
      if (e.key === 'ArrowRight') { e.preventDefault(); showSlide(current + 1); }
      if (e.key === 'ArrowLeft')  { e.preventDefault(); showSlide(current - 1); }
    });

    /* Swipe inside lightbox */
    let lbTx = 0;
    lb.addEventListener('touchstart', (e: TouchEvent) => {
      lbTx = e.touches[0].clientX;
    }, { passive: true });
    lb.addEventListener('touchend', (e: TouchEvent) => {
      const diff = lbTx - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 50) showSlide(diff > 0 ? current + 1 : current - 1);
    }, { passive: true });
  })();


  /* ═══════════════════════════════════════════════
     SCROLL REVEAL
     ═══════════════════════════════════════════════ */
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        (e.target as HTMLElement).style.opacity   = '1';
        (e.target as HTMLElement).style.transform  = 'translateY(0)';
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.08 });

  document.querySelectorAll<HTMLElement>('.scard,.pcard,.eitem,.educard,.icard,.clink').forEach(el => {
    el.style.opacity    = '0';
    el.style.transform  = 'translateY(28px)';
    el.style.transition = 'opacity 0.55s ease, transform 0.55s ease';
    obs.observe(el);
  });
</script>
</body>
</html>
