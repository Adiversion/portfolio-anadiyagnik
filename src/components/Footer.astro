---
const year = new Date().getFullYear();
---

<footer>
  <div class="footer-name">Anadi Shankar Yagnik</div>
  <div class="footer-note">
    Senior Accountant · Finance Automation Specialist · Raipur, India
  </div>
  <div class="footer-copy">© {year} All rights reserved</div>
</footer>

<style>
  footer {
    padding: 2rem 4rem;
    border-top: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
    background: var(--navy-2);
  }
  .footer-name {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: var(--gold);
  }
  .footer-note {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    color: var(--slate);
  }
  .footer-copy {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--slate);
    opacity: 0.6;
  }

  @media (max-width: 600px) {
    footer { padding: 1.5rem; justify-content: center; text-align: center; }
  }
</style>
