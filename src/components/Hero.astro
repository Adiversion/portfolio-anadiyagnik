---
---

<section class="hero" id="home">
  <div class="hero-grid-bg"></div>
  <div class="hero-glow"></div>
  <div class="hero-glow-2"></div>

  <div class="hero-content">
    <div class="hero-tag">Open to Remote Opportunities</div>

    <h1>Anadi Shankar<br /><em>Yagnik</em></h1>
    <p class="hero-subtitle">Senior Accountant &amp; Finance Automation Specialist · Raipur, India</p>

    <p class="hero-desc">
      I don't just record transactions — I <strong>build the systems</strong> that make
      reporting faster, error-free, and audit-ready. Specialising in multi-entity
      <strong>GST/TDS compliance</strong> automated with Excel, VBA, Power Query,
      and Tally ODBC integrations.
    </p>

    <div class="hero-cta">
      <a class="btn-primary" href="#projects">View Projects ↓</a>
      <a class="btn-ghost" href="mailto:anadisyagnik@gmail.com">Get in Touch →</a>
    </div>

    <div class="hero-stats">
      <div class="stat-item">
        <div class="stat-num">12+</div>
        <div class="stat-label">Years Experience</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">8</div>
        <div class="stat-label">Group Entities</div>
      </div>
      <div class="stat-item">
        <div class="stat-num">70%</div>
        <div class="stat-label">Time Saved (TDS)</div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 8rem 4rem 6rem;
    position: relative;
    overflow: hidden;
  }
  .hero-grid-bg {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(201,168,76,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(201,168,76,0.04) 1px, transparent 1px);
    background-size: 60px 60px;
  }
  .hero-glow {
    position: absolute;
    top: -200px; right: -200px;
    width: 700px; height: 700px;
    background: radial-gradient(circle, rgba(201,168,76,0.08) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-glow-2 {
    position: absolute;
    bottom: -300px; left: -100px;
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(62,207,142,0.05) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-content {
    position: relative;
    max-width: 900px;
  }
  .hero-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--green);
    border: 1px solid rgba(62,207,142,0.3);
    padding: 0.35rem 0.9rem;
    border-radius: 2px;
    margin-bottom: 2rem;
    animation: fadeUp 0.6s ease both;
  }
  .hero-tag::before {
    content: '';
    width: 6px; height: 6px;
    background: var(--green);
    border-radius: 50%;
    animation: pulse 2s infinite;
  }
  h1 {
    font-family: var(--font-serif);
    font-size: clamp(3rem, 7vw, 5.5rem);
    line-height: 1.08;
    color: var(--white);
    margin-bottom: 0.5rem;
    animation: fadeUp 0.6s 0.1s ease both;
  }
  h1 em { font-style: italic; color: var(--gold); }

  .hero-subtitle {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--slate);
    letter-spacing: 0.05em;
    margin-bottom: 2rem;
    animation: fadeUp 0.6s 0.2s ease both;
  }
  .hero-desc {
    font-size: 1.1rem;
    color: var(--slate-lt);
    max-width: 640px;
    line-height: 1.8;
    margin-bottom: 3rem;
    animation: fadeUp 0.6s 0.3s ease both;
  }
  .hero-desc strong { color: var(--gold-lt); font-weight: 600; }

  .hero-cta {
    display: flex;
    gap: 1.2rem;
    flex-wrap: wrap;
    animation: fadeUp 0.6s 0.4s ease both;
  }

  .hero-stats {
    display: flex;
    gap: 3rem;
    margin-top: 4rem;
    animation: fadeUp 0.6s 0.5s ease both;
  }
  .stat-num {
    font-family: var(--font-serif);
    font-size: 2.8rem;
    color: var(--gold);
    line-height: 1;
  }
  .stat-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--slate);
    margin-top: 0.25rem;
  }

  @media (max-width: 768px) {
    .hero { padding: 7rem 1.5rem 4rem; }
    .hero-stats { gap: 2rem; flex-wrap: wrap; }
  }
</style>
