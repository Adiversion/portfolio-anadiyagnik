---
const contactLinks = [
  {
    icon: "✉️",
    label: "Email",
    value: "anadisyagnik@gmail.com",
    href: "mailto:anadisyagnik@gmail.com",
  },
  {
    icon: "📞",
    label: "Phone",
    value: "+91 89668 53253",
    href: "tel:+918966853253",
  },
  {
    icon: "🔗",
    label: "LinkedIn",
    value: "linkedin.com/in/anadi-yagnik",
    href: "https://linkedin.com/in/anadi-yagnik",
    target: "_blank",
  },
];
---

<section class="contact" id="contact">
  <div class="section-label">Get in Touch</div>
  <div class="contact-inner">

    <div class="contact-left">
      <h2>Let's Build Something <em>Efficient</em></h2>
      <p class="contact-note">
        I'm actively seeking <strong>remote opportunities</strong> where I can deploy
        my finance automation skills to drive efficiency for forward-thinking teams.
        Whether you have a role, a project, or just want to connect — I'd love to hear from you.
      </p>
      <div class="availability">Available for Remote Roles</div>
    </div>

    <div class="contact-links">
      {contactLinks.map(link => (
        <a
          class="contact-link"
          href={link.href}
          target={link.target ?? undefined}
          rel={link.target === "_blank" ? "noopener noreferrer" : undefined}
        >
          <span class="contact-link-icon">{link.icon}</span>
          <div class="contact-link-info">
            <span class="contact-link-label">{link.label}</span>
            <span class="contact-link-value">{link.value}</span>
          </div>
          <span class="contact-link-arrow">→</span>
        </a>
      ))}
    </div>

  </div>
</section>

<style>
  .contact { background: var(--navy); }

  .contact-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  .contact-note {
    font-size: 1rem;
    color: var(--slate);
    line-height: 1.9;
    margin-bottom: 2rem;
  }
  .contact-note strong { color: var(--gold-lt); }

  .availability {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--green);
    border: 1px solid rgba(62,207,142,0.25);
    padding: 0.6rem 1.2rem;
    border-radius: 2px;
    background: rgba(62,207,142,0.07);
  }
  .availability::before {
    content: '';
    width: 7px; height: 7px;
    background: var(--green);
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  .contact-links { display: flex; flex-direction: column; gap: 1rem; }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    border: 1px solid var(--border);
    background: var(--navy-3);
    padding: 1.25rem 1.75rem;
    border-radius: 4px;
    color: var(--slate-lt);
    transition: border-color 0.3s, transform 0.3s;
  }
  .contact-link:hover { border-color: var(--gold); color: var(--gold-lt); transform: translateX(6px); }

  .contact-link-icon { font-size: 1.2rem; }
  .contact-link-info { flex: 1; display: flex; flex-direction: column; }
  .contact-link-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--slate);
    margin-bottom: 0.2rem;
  }
  .contact-link-value { font-size: 0.95rem; color: inherit; }
  .contact-link-arrow { color: var(--slate); transition: color 0.2s; }
  .contact-link:hover .contact-link-arrow { color: var(--gold); }

  @media (max-width: 900px) {
    .contact-inner { grid-template-columns: 1fr; gap: 3rem; }
  }
</style>
